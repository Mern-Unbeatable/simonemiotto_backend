{
  "info": {
    "name": "Property Management API",
    "description": "Complete API collection for Property Management Platform\n\nAuthor: McCann & Curran Development Team\nVersion: 1.0.0\n\n**Authentication:**\n- Most endpoints require Bearer token in Authorization header\n- Register/Login to get access tokens\n- Tokens automatically set in environment variables\n\n**Base URL:** http://localhost:3001\n\n**Available Modules:**\n- System Health & Status\n- Authentication & User Management\n- Properties (Coming Soon)\n- Tenancies (Coming Soon)\n- Maintenance (Coming Soon)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "property-management-api"
  },
  "item": [
    {
      "name": "🔧 System & Health",
      "item": [
        {
          "name": "Root Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "response": []
        },
        {
          "name": "API Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "health"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has success property', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('success');",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "});",
                  "",
                  "pm.test('Health data is present', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('status');",
                  "    pm.expect(jsonData.data.status).to.eql('OK');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "API Documentation",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/docs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "docs"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Documentation contains API endpoints', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('API_ENDPOINTS');",
                  "    pm.expect(jsonData.data.API_ENDPOINTS).to.have.property('AUTH');",
                  "    pm.expect(jsonData.data.API_ENDPOINTS).to.have.property('USERS');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
