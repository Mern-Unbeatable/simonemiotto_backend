{
  "info": {
    "name": "MonsResourcesAPI",
    "description": "Complete Auth API collection for MonsResourcesAPI\n\n**Authentication:**\n- Register or Login to get access & refresh tokens\n- Tokens are auto-saved to environment variables via test scripts\n\n**Base URL:** http://localhost:3002\n**API Prefix:** /api/v1\n\n**Roles:** ADMIN | ORGANIZER | USER",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register USER",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"user@example.com\",\n  \"password\": \"TestPassword123!\",\n  \"role\": \"USER\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"phoneNumber\": \"01700000000\",\n  \"gender\": \"MALE\",\n  \"dateOfBirth\": \"1995-06-15\",\n  \"address\": \"123 Main Street\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.tokens) {",
                  "  pm.environment.set('accessToken', json.data.tokens.accessToken);",
                  "  pm.environment.set('refreshToken', json.data.tokens.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
